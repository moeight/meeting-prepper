{
  "builds": [
    { "src": "api/brief.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/brief", "dest": "api/brief.py" },
    { "src": "/(.*)", "dest": "public/$1" }
  ],
  "functions": {
    "api/brief.py": {
      "maxDuration": 60
    }
  }
}
